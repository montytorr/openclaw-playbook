{
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      }
    },
    "order": {
      "openai-codex": [
        "openai-codex:default"
      ]
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.4",
        "fallbacks": [
          "openai-codex/gpt-5.3-codex"
        ]
      },
      "models": {
        "openai-codex/gpt-5.4": {
          "alias": "codex"
        },
        "openai-codex/gpt-5.3-codex": {},
        "openai-codex/gpt-5.3-codex-spark": {
          "alias": "spark"
        }
      },
      "workspace": "/root/clawd",
      "thinkingDefault": "medium",
      "subagents": {
        "thinking": "off"
      },
      "bootstrapFiles": [
        "AGENTS.md",
        "SOUL.md",
        "IDENTITY.md",
        "USER.md",
        "TOOLS.md"
      ],
      "bootstrapMaxChars": 20000,
      "bootstrapTotalMaxChars": 50000,
      "imageGenerationModel": {
        "primary": "openai/gpt-image-1"
      }
    },
    "list": [
      {
        "id": "main",
        "name": "<YOUR_AGENT_NAME>"
      }
    ]
  },
  "memorySearch": {
    "provider": "local",
    "fallback": "none",
    "sources": [
      "memory",
      "sessions"
    ]
  },
  "channels": {
    "discord": {
      "token": "<YOUR_DISCORD_BOT_TOKEN>",
      "allowedChannels": [
        "<CHANNEL_ID>"
      ]
    }
  },
  "hooks": [
    {
      "name": "the-wall",
      "path": "hooks/the-wall/index.ts",
      "events": ["before_tool_call"],
      "enabled": true
    },
    {
      "name": "agent-firewall",
      "path": "hooks/agent-firewall/index.ts",
      "events": ["session_start"],
      "enabled": true
    },
    {
      "name": "auto-git-commit",
      "path": "hooks/auto-git-commit/index.ts",
      "events": ["after_tool_call"],
      "enabled": true
    },
    {
      "name": "llm-observer",
      "path": "hooks/llm-observer/index.ts",
      "events": ["after_llm_call"],
      "enabled": true
    },
    {
      "name": "message-logger",
      "path": "hooks/message-logger/index.ts",
      "events": ["message_sent", "message_received"],
      "enabled": true
    }
  ],
  "cron": {
    "jobs": [
      {
        "id": "heartbeat",
        "name": "Heartbeat",
        "enabled": true,
        "schedule": {
          "kind": "cron",
          "expr": "*/30 * * * *"
        },
        "sessionTarget": "main",
        "payload": {
          "kind": "systemEvent",
          "text": "Read HEARTBEAT.md if it exists (workspace context). Follow it strictly. Do not infer or repeat old tasks from prior chats. If nothing needs attention, reply HEARTBEAT_OK."
        }
      },
      {
        "id": "morning-brief",
        "name": "Morning Briefing",
        "enabled": true,
        "schedule": {
          "kind": "cron",
          "expr": "30 8 * * 1-5",
          "tz": "<YOUR_TIMEZONE>"
        },
        "sessionTarget": "isolated",
        "payload": {
          "kind": "agentTurn",
          "message": "Generate a morning briefing: check calendar, scan email for urgent items, summarize any overnight activity.",
          "model": "openai-codex/gpt-5.4",
          "thinking": "medium",
          "timeoutSeconds": 600
        },
        "delivery": {
          "mode": "announce",
          "channel": "<YOUR_CHANNEL_ID>"
        }
      },
      {
        "id": "nightly-health",
        "name": "Nightly Health Check",
        "enabled": true,
        "schedule": {
          "kind": "cron",
          "expr": "0 2 * * *",
          "tz": "UTC"
        },
        "sessionTarget": "isolated",
        "payload": {
          "kind": "agentTurn",
          "message": "Run system health check. Only report if something needs attention.",
          "model": "openai-codex/gpt-5.3-codex",
          "thinking": "low",
          "timeoutSeconds": 300
        },
        "delivery": {
          "mode": "announce",
          "channel": "<YOUR_CHANNEL_ID>"
        }
      },
      {
        "id": "spark-availability-refresh",
        "name": "Spark Availability Refresh",
        "enabled": true,
        "schedule": {
          "kind": "every",
          "everyMs": 900000
        },
        "sessionTarget": "isolated",
        "payload": {
          "kind": "agentTurn",
          "message": "Refresh quota/router state for Spark availability and stay silent on success.",
          "timeoutSeconds": 180
        },
        "delivery": {
          "mode": "none"
        }
      }
    ]
  },
  "messages": {
    "tts": {
      "provider": "elevenlabs",
      "voice": "<YOUR_VOICE_ID>",
      "model": "eleven_multilingual_v2",
      "auto": "inbound",
      "fallback": {
        "provider": "openai",
        "voice": "fable"
      }
    }
  },
  "plugins": {
    "allow": [
      "discord",
      "browser",
      "openai",
      "quota-aware-codex-router"
    ],
    "entries": {
      "device-pair": {
        "enabled": true,
        "config": {
          "publicUrl": "<YOUR_GATEWAY_PUBLIC_URL>"
        }
      },
      "quota-aware-codex-router": {
        "enabled": true,
        "config": {}
      }
    }
  },
  "gateway": {
    "bind": "0.0.0.0:18789",
    "remote": {
      "url": "<YOUR_GATEWAY_PUBLIC_URL>"
    }
  }
}
