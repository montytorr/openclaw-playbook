#!/usr/bin/env python3
"""Educational scaffold, not production hardened.

Tiny integrity checker for protected workspace files.
Commands:
- init  : create/update the hash baseline
- check : compare current files to the baseline
- show  : print the stored baseline
"""

import argparse
import hashlib
import json
import os
import sys
from pathlib import Path

WORKSPACE_ROOT = Path(os.environ.get("WORKSPACE_ROOT", Path.home() / "clawd")).resolve()
BASELINE_PATH = WORKSPACE_ROOT / ".integrity-hashes"
PROTECTED_FILES = [
    "AGENTS.md",
    "SOUL.md",
    "IDENTITY.md",
    "USER.md",
    "HEARTBEAT.md",
    "TOOLS.md",
    "SECURITY.md",
]


def sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as fh:
        for chunk in iter(lambda: fh.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def collect():
    records = {}
    for rel in PROTECTED_FILES:
        path = WORKSPACE_ROOT / rel
        if path.exists():
            records[rel] = sha256(path)
    return records


def load_baseline():
    if not BASELINE_PATH.exists():
        return None
    return json.loads(BASELINE_PATH.read_text())


def cmd_init():
    baseline = collect()
    BASELINE_PATH.write_text(json.dumps(baseline, indent=2, sort_keys=True) + "\n")
    print(f"integrity baseline written: {BASELINE_PATH}")
    return 0


def cmd_show():
    baseline = load_baseline()
    if baseline is None:
        print("no baseline found", file=sys.stderr)
        return 2
    print(json.dumps(baseline, indent=2, sort_keys=True))
    return 0


def cmd_check():
    baseline = load_baseline()
    if baseline is None:
        print("no baseline found, run: integrity-check init", file=sys.stderr)
        return 2

    current = collect()
    problems = []

    for rel, expected in baseline.items():
        current_hash = current.get(rel)
        if current_hash is None:
            problems.append(f"missing: {rel}")
        elif current_hash != expected:
            problems.append(f"changed: {rel}")

    for rel in sorted(set(current) - set(baseline)):
        problems.append(f"newly-tracked-candidate: {rel}")

    if problems:
        print("integrity drift detected:")
        for item in problems:
            print(f"- {item}")
        return 1

    print("integrity-check: ok")
    return 0


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("command", choices=["init", "check", "show"])
    args = parser.parse_args()

    if args.command == "init":
        raise SystemExit(cmd_init())
    if args.command == "show":
        raise SystemExit(cmd_show())
    raise SystemExit(cmd_check())


if __name__ == "__main__":
    main()
