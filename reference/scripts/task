#!/usr/bin/env python3
"""Educational scaffold, not production hardened.

Tiny SQLite-backed task CLI for the playbook reference implementation.
Default workspace root: ~/clawd (override with WORKSPACE_ROOT=/path).
"""

import os
import sqlite3
import sys
import uuid
from pathlib import Path

WORKSPACE_ROOT = Path(os.environ.get("WORKSPACE_ROOT", str(Path.home() / "clawd")))
DB_PATH = WORKSPACE_ROOT / "data" / "agent.db"

EXIT_USAGE = 1
EXIT_NOT_FOUND = 2
VALID_STATUSES = {"in-progress", "done", "planned"}

SCHEMA = """
CREATE TABLE IF NOT EXISTS tasks (
    id TEXT PRIMARY KEY,
    title TEXT NOT NULL,
    input TEXT,
    output TEXT,
    status TEXT NOT NULL DEFAULT 'planned'
        CHECK (status IN ('in-progress', 'done', 'planned')),
    category TEXT NOT NULL DEFAULT 'other',
    priority TEXT NOT NULL DEFAULT 'medium'
        CHECK (priority IN ('low', 'medium', 'high', 'urgent')),
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    updated_at TEXT NOT NULL DEFAULT (datetime('now'))
);
CREATE INDEX IF NOT EXISTS idx_tasks_status ON tasks(status);
CREATE INDEX IF NOT EXISTS idx_tasks_category ON tasks(category);
CREATE INDEX IF NOT EXISTS idx_tasks_updated ON tasks(updated_at DESC);
"""


def conn():
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    c = sqlite3.connect(DB_PATH)
    c.row_factory = sqlite3.Row
    c.executescript(SCHEMA)
    return c


def new_id() -> str:
    return uuid.uuid4().hex[:8]


def usage():
    print(
        "usage: task <start|done|plan|update|set-input|list|show|search|delete|sprint> ...",
        file=sys.stderr,
    )
    sys.exit(EXIT_USAGE)


def require_args(args, minimum):
    if len(args) < minimum:
        usage()


def fail(message, code=EXIT_USAGE):
    print(message, file=sys.stderr)
    raise SystemExit(code)


def ensure_valid_status(status):
    if status not in VALID_STATUSES:
        fail(f"invalid status: {status}")


def find_task_or_fail(c, task_id):
    row = c.execute("SELECT * FROM tasks WHERE id=?", (task_id,)).fetchone()
    if not row:
        fail(f"task not found: {task_id}", EXIT_NOT_FOUND)
    return row


def find_matching_in_progress(c, title, input_text, category, priority):
    return c.execute(
        """
        SELECT id FROM tasks
        WHERE status='in-progress'
          AND title=?
          AND COALESCE(input,'')=COALESCE(?, '')
          AND category=?
          AND priority=?
        ORDER BY updated_at DESC
        LIMIT 1
        """,
        (title, input_text, category, priority),
    ).fetchone()


def cmd_start(args):
    require_args(args, 1)
    title = args[0]
    input_text = args[1] if len(args) > 1 else None
    category = args[2] if len(args) > 2 else "other"
    priority = args[3] if len(args) > 3 else "medium"
    with conn() as c:
        existing = find_matching_in_progress(c, title, input_text, category, priority)
        if existing:
            c.execute(
                "UPDATE tasks SET updated_at=datetime('now') WHERE id=?",
                (existing["id"],),
            )
            print(existing["id"])
            return
        task_id = new_id()
        c.execute(
            "INSERT INTO tasks (id, title, input, status, category, priority) VALUES (?, ?, ?, 'in-progress', ?, ?)",
            (task_id, title, input_text, category, priority),
        )
    print(task_id)


def cmd_done(args):
    require_args(args, 1)
    title = args[0]
    input_text = args[1] if len(args) > 1 else None
    output = args[2] if len(args) > 2 else None
    category = args[3] if len(args) > 3 else "other"
    with conn() as c:
        row = c.execute(
            "SELECT id FROM tasks WHERE status='in-progress' AND title=? ORDER BY updated_at DESC LIMIT 1",
            (title,),
        ).fetchone()
        if row:
            c.execute(
                "UPDATE tasks SET status='done', output=?, updated_at=datetime('now') WHERE id=?",
                (output, row["id"]),
            )
            print(row["id"])
        else:
            task_id = new_id()
            c.execute(
                "INSERT INTO tasks (id, title, input, output, status, category) VALUES (?, ?, ?, ?, 'done', ?)",
                (task_id, title, input_text, output, category),
            )
            print(task_id)


def cmd_plan(args):
    require_args(args, 1)
    title = args[0]
    input_text = args[1] if len(args) > 1 else None
    category = args[2] if len(args) > 2 else "other"
    with conn() as c:
        row = c.execute(
            "SELECT id FROM tasks WHERE status='planned' AND title=? AND COALESCE(input,'')=COALESCE(?, '') AND category=? ORDER BY updated_at DESC LIMIT 1",
            (title, input_text, category),
        ).fetchone()
        if row:
            c.execute("UPDATE tasks SET updated_at=datetime('now') WHERE id=?", (row["id"],))
            print(row["id"])
            return
        task_id = new_id()
        c.execute(
            "INSERT INTO tasks (id, title, input, status, category) VALUES (?, ?, ?, 'planned', ?)",
            (task_id, title, input_text, category),
        )
    print(task_id)


def cmd_update(args):
    require_args(args, 2)
    task_id, status = args[0], args[1]
    desc = args[2] if len(args) > 2 else None
    ensure_valid_status(status)
    with conn() as c:
        find_task_or_fail(c, task_id)
        if status == "done" and desc is not None:
            c.execute(
                "UPDATE tasks SET status=?, output=?, updated_at=datetime('now') WHERE id=?",
                (status, desc, task_id),
            )
        else:
            c.execute(
                "UPDATE tasks SET status=?, updated_at=datetime('now') WHERE id=?",
                (status, task_id),
            )
    print(task_id)


def cmd_set_input(args):
    require_args(args, 2)
    task_id, input_text = args[0], args[1]
    with conn() as c:
        find_task_or_fail(c, task_id)
        c.execute(
            "UPDATE tasks SET input=?, updated_at=datetime('now') WHERE id=?",
            (input_text, task_id),
        )
    print(task_id)


def cmd_list(args):
    status = None
    limit = 10
    i = 0
    while i < len(args):
        if args[i] == "--limit":
            if i + 1 >= len(args):
                usage()
            limit = int(args[i + 1])
            i += 2
        else:
            status = args[i]
            i += 1
    if status is not None:
        ensure_valid_status(status)
    q = "SELECT id, status, category, title, updated_at FROM tasks"
    params = []
    if status:
        q += " WHERE status=?"
        params.append(status)
    q += " ORDER BY updated_at DESC LIMIT ?"
    params.append(limit)
    with conn() as c:
        for row in c.execute(q, params):
            print(
                f"{row['id']}\t{row['status']}\t{row['category']}\t{row['title']}\t{row['updated_at']}"
            )


def cmd_show(args):
    require_args(args, 1)
    with conn() as c:
        row = find_task_or_fail(c, args[0])
        for k in row.keys():
            print(f"{k}: {row[k]}")


def cmd_search(args):
    require_args(args, 1)
    q = "%" + args[0] + "%"
    with conn() as c:
        for row in c.execute(
            "SELECT id, status, title FROM tasks WHERE title LIKE ? OR input LIKE ? OR output LIKE ? ORDER BY updated_at DESC LIMIT 20",
            (q, q, q),
        ):
            print(f"{row['id']}\t{row['status']}\t{row['title']}")


def cmd_delete(args):
    require_args(args, 1)
    task_id = args[0]
    with conn() as c:
        find_task_or_fail(c, task_id)
        c.execute("DELETE FROM tasks WHERE id=?", (task_id,))
    print(task_id)


def cmd_sprint(args):
    status = None
    i = 0
    while i < len(args):
        if args[i] == "--status":
            if i + 1 >= len(args):
                usage()
            status = args[i + 1]
            i += 2
        else:
            status = args[i]
            i += 1
    if status is not None:
        ensure_valid_status(status)
    q = "SELECT id, status, category, title FROM tasks"
    params = []
    if status:
        q += " WHERE status=?"
        params.append(status)
    q += " ORDER BY category ASC, updated_at DESC"

    with conn() as c:
        rows = list(c.execute(q, params))
    if not rows:
        return

    current = None
    current_rows = []
    for row in rows:
        if row["category"] != current:
            if current_rows:
                print(f"=== {current} ({len(current_rows)} tasks) ===")
                for item in current_rows:
                    print(f"  [{item['status']}] {item['id']}  {item['title']}")
                print()
            current = row["category"]
            current_rows = [row]
        else:
            current_rows.append(row)

    if current_rows:
        print(f"=== {current} ({len(current_rows)} tasks) ===")
        for item in current_rows:
            print(f"  [{item['status']}] {item['id']}  {item['title']}")


COMMANDS = {
    "start": cmd_start,
    "done": cmd_done,
    "plan": cmd_plan,
    "update": cmd_update,
    "set-input": cmd_set_input,
    "list": cmd_list,
    "show": cmd_show,
    "search": cmd_search,
    "delete": cmd_delete,
    "sprint": cmd_sprint,
}


if __name__ == "__main__":
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        usage()
    COMMANDS[sys.argv[1]](sys.argv[2:])
